{
    "name": "@mustafagoksever/java-inspector",
    "version": "2.4.0",
    "description": "MCP server that gives AI agents instant access to decompiled Java code from Maven dependencies. Blazing fast Java class analysis for Claude, Cursor, and other LLM-powered IDEs.",
    "main": "dist/index.js",
    "bin": {
        "java-inspector": "dist/cli.js"
    },
    "type": "module",
    "files": [
        "dist/**/*",
        "lib/**/*",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "tsx src/index.ts",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
        "prepublishOnly": "npm run build",
        "prepack": "npm run build",
        "publish:npm": "npm publish",
        "publish:beta": "npm publish --tag beta",
        "version:patch": "npm version patch",
        "version:minor": "npm version minor",
        "version:major": "npm version major"
    },
    "keywords": [
        "mcp",
        "model-context-protocol",
        "java",
        "decompiler",
        "decompilation",
        "java-decompiler",
        "maven",
        "claude",
        "cursor",
        "ai",
        "llm",
        "java-inspector",
        "spring",
        "spring-boot",
        "jar",
        "bytecode",
        "reverse-engineering",
        "class-analyzer",
        "dependency-analysis",
        "intellij",
        "vscode",
        "ai-assistant",
        "copilot",
        "anthropic",
        "opencode",
        "agent",
        "ai-agent"
    ],
    "author": "mustafagoksever",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mustafagoksever/java-inspector.git"
    },
    "bugs": {
        "url": "https://github.com/mustafagoksever/java-inspector/issues"
    },
    "homepage": "https://github.com/mustafagoksever/java-inspector#readme",
    "engines": {
        "node": ">=16.0.0"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.25.3",
        "@toon-format/toon": "^2.1.0",
        "commander": "^14.0.2",
        "fs-extra": "^11.3.3",
        "proper-lockfile": "^4.1.2",
        "yauzl": "^3.2.0"
    },
    "devDependencies": {
        "@types/archiver": "^6.0.2",
        "@types/fs-extra": "^11.0.4",
        "@types/jest": "^29.5.13",
        "@types/node": "^22.10.0",
        "@types/proper-lockfile": "^4.1.4",
        "@types/yauzl": "^2.10.3",
        "archiver": "^7.0.1",
        "jest": "^29.7.0",
        "ts-jest": "^29.4.9",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0"
    }
}
